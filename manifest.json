{
  "manifest_version": 3,
  "name": "Make It Ransomy",
  "description": "Turns ChatGPT messages ransom-note style. Inspired by Allison Parrish's 'Language models can only write ransom notes.'",
  "version": "2.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  }
}
